{
  "expo": {
    "name": "Outpost",
    "slug": "godx-outpost",
    "version": "0.1.0",
    "orientation": "default",
    "scheme": "outpost",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0d0d0d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "jp.godx.outpost",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to scan the pairing QR code displayed on the host."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4589F1"
      },
      "package": "jp.godx.outpost",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Outpost to access your camera to scan the pairing QR code."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Outpost to access your photos so you can send an image to the terminal."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
